ISCHE TIPPS", "target": "PRAXISBEISPIELE FÜR KULTURSENSIBLE KOMMUNIKATION", "type": "NEXT", "value": ""}, {"source": "PRAXISBEISPIELE FÜR KULTURSENSIBLE KOMMUNIKATION", "target": "FAZIT:", "type": "NEXT", "value": ""}, {"source": "Trauma & Flucht", "target": "Gliederung", "type": "NEXT", "value": ""}, {"source": "Gliederung", "target": "Einführung", "type": "NEXT", "value": ""}, {"source": "Einführung", "target": "Hintergründe der Flucht von UMF", "type": "NEXT", "value": ""}, {"source": "Hintergründe der Flucht von UMF", "target": "Spezifische Hintergründe der Flucht von Mädchen und Frauen", "type": "NEXT", "value": ""}, {"source": "Spezifische Hintergründe der Flucht von Mädchen und Frauen", "target": "Auf der Flucht", "type": "NEXT", "value": ""}, {"source": "Auf der Flucht", "target": "POTENTIELL TRAUMATISCHE EREIGNISSE", "type": "NEXT", "value": ""}, {"source": "POTENTIELL TRAUMATISCHE EREIGNISSE", "target": "06.04.2025", "type": "NEXT", "value": ""}, {"source": "06.04.2025", "target": "Migration", "type": "NEXT", "value": ""}, {"source": "Migration", "target": "PHASEN DER MIGRATION", "type": "NEXT", "value": ""}, {"source": "PHASEN DER MIGRATION", "target": "Kulturelle Adoleszenz", "type": "NEXT", "value": ""}, {"source": "Kulturelle Adoleszenz", "target": "Phasen des Migrationsprozesses", "type": "NEXT", "value": ""}, {"source": "Phasen des Migrationsprozesses", "target": "MIGRATION UND IDENTITÄT", "type": "NEXT", "value": ""}, {"source": "MIGRATION UND IDENTITÄT", "target": "sequentielle Traumatisierung (Keilson, 1979)", "type": "NEXT", "value": ""}, {"source": "sequentielle Traumatisierung (Keilson, 1979)", "target": "Das Fremde und das Eigene", "type": "NEXT", "value": ""}, {"source": "Das Fremde und das Eigene", "target": "DIE FRAGE NACH KULTUR", "type": "NEXT", "value": ""}, {"source": "DIE FRAGE NACH KULTUR", "target": "Kultur ist ... I", "type": "NEXT", "value": ""}, {"source": "Kultur ist ... I", "target": "Kultur ist....", "type": "NEXT", "value": ""}, {"source": "Kultur ist....", "target": "„Kultur“ als Vermeidung", "type": "NEXT", "value": ""}, {"source": "„Kultur“ als Vermeidung", "target": "Multi-Kulti", "type": "NEXT", "value": ""}, {"source": "Multi-Kulti", "target": "Transkulturalität", "type": "NEXT", "value": ""}, {"source": "Transkulturalität", "target": "„Das Fremde ist in mir, also sind wir alle Fremde“(J. Kristeva1990)", "type": "NEXT", "value": ""}, {"source": "„Das Fremde ist in mir, also sind wir alle Fremde“(J. Kristeva1990)", "target": "Primat der Begegnung", "type": "NEXT", "value": ""}, {"source": "Primat der Begegnung", "target": "Kultur und Exil", "type": "NEXT", "value": ""}, {"source": "Kultur und Exil", "target": "Die Begegnung mit dem Verlust", "type": "NEXT", "value": ""}, {"source": "Die Begegnung mit dem Verlust", "target": "Es ist ein Unmögliches sich in alltäglichen Situationen der Kultur zu entziehen, denn wir sind ständig Teil davon. Gerade deswegen kann es sich als schwer herausstellen, kulturelle Leistungen bewusst wahrzunehmen.", "type": "NEXT", "value": ""}, {"source": "Es ist ein Unmögliches sich in alltäglichen Situationen der Kultur zu entziehen, denn wir sind ständig Teil davon. Gerade deswegen kann es sich als schwer herausstellen, kulturelle Leistungen bewusst wahrzunehmen.", "target": "DIE FRAGE NACH IDENTITÄT", "type": "NEXT", "value": ""}, {"source": "DIE FRAGE NACH IDENTITÄT", "target": "Das Leben im Exil", "type": "NEXT", "value": ""}, {"source": "Das Leben im Exil", "target": "Handlungsspielräume nach dem Konzept der Lebenslagen (Glatzer und Hübinger, 1990)", "type": "NEXT", "value": ""}, {"source": "Handlungsspielräume nach dem Konzept der Lebenslagen (Glatzer und Hübinger, 1990)", "target": "Akkulturationsprozesse", "type": "NEXT", "value": ""}, {"source": "Akkulturationsprozesse", "target": "Flucht, Migration und Identität", "type": "NEXT", "value": ""}, {"source": "Flucht, Migration und Identität", "target": "Auswirkungen auf die Identität", "type": "NEXT", "value": ""}, {"source": "Auswirkungen auf die Identität", "target": "Von der Transkulturellen Identität zur Hybriden Identität", "type": "NEXT", "value": ""}, {"source": "Von der Transkulturellen Identität zur Hybriden Identität", "target": "Vererbte Wunden: Gefahr der transgenerationalen Weitergabe", "type": "NEXT", "value": ""}, {"source": "Vererbte Wunden: Gefahr der transgenerationalen Weitergabe", "target": "Fragen ???", "type": "NEXT", "value": ""}, {"source": "Psychodynamik der Traumatisierung & das Verlaufsmodell nach Fischer", "target": "INHALTSVERZEICHNIS", "type": "NEXT", "value": ""}, {"source": "INHALTSVERZEICHNIS", "target": "19.10.2018", "type": "NEXT", "value": ""}, {"source": "19.10.2018", "target": "Paradoxie der traumatischen Situation", "type": "NEXT", "value": ""}, {"source": "Paradoxie der traumatischen Situation", "target": "Erste Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "type": "NEXT", "value": ""}, {"source": "Erste Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "target": "19.10.2018", "type": "NEXT", "value": ""}, {"source": "19.10.2018", "target": "Zweite Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "type": "NEXT", "value": ""}, {"source": "Zweite Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "target": "Dritte Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "type": "NEXT", "value": ""}, {"source": "Dritte Phase des Verlaufsmodells (nach G. Fischer, P. Riedesser)", "target": "Der Widerspruch als Grundlage des Verständnisses", "type": "NEXT", "value": ""}, {"source": "Der Widerspruch als Grundlage des Verständnisses", "target": "DIE PERITRAUMATISCHE SITUATION", "type": "NEXT", "value": ""}, {"source": "DIE PERITRAUMATISCHE SITUATION", "target": "Die peritraumatische Situation", "type": "NEXT", "value": ""}, {"source": "Die peritraumatische Situation", "target": "19.10.2018", "type": "NEXT", "value": ""}, {"source": "19.10.2018", "target": "TRAUMASCHEMA UND TRAUMAKOMPENS